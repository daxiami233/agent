# Model provider
API_KEY=
BASE_URL=
MODEL=
PROVIDER_API=auto
MAX_RETRIES=2
PROVIDER_TIMEOUT_SECONDS=60

# Context budget
CONTEXT_WINDOW=32000
RESERVED_OUTPUT_TOKENS=4000
CONTEXT_SAFETY_MARGIN=1000
COMPACT_THRESHOLD_RATIO=0.8
RECENT_TURNS=6
COMPACT_SUMMARY_TOKENS=1200
RAW_KEEP_RATIO=0.6

# Runtime storage
AGENT_RUNTIME_DATA_DIR=~/.agent-runtime
MEMORY_BACKEND=sqlite
LONG_TERM_MEMORY_MAX_LINES=200

# Built-in tools
ENABLE_MEMORY_TOOLS=true
ENABLE_SKILL_TOOLS=true
ENABLE_SHELL_TOOL=true
SHELL_TIMEOUT_SECONDS=30
SHELL_MAX_OUTPUT_CHARS=20000

# Skills
# Use the OS path separator for multiple paths.
SKILL_PATHS=
